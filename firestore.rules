rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regla de Oro (Deny all unless specified)
    match /{document=**} {
      allow read, write: if false;
    }

    // Prevención de escalada de privilegios y bypass de facturación
    function hasProtectedFields() {
      let isCreate = resource == null;
      let keysToCheck = isCreate ? request.resource.data.keys() : request.resource.data.diff(resource.data).affectedKeys();
      
      return keysToCheck.hasAny([
        'subscriptionStatus', 
        'isPro', 
        'plan', 
        'redeemCode', 
        'redeemedAt',
        'planExpiry',
        'planLabel',
        'lemonCustomerId',
        'lemonSubscriptionId',
        'lemonVariantId',
        'lemonRenewsAt',
        'lemonCancelled',
        'lemonCustomerPortalUrl'
      ]);
    }
    
    match /users/{userId} {
      // Perfil principal del usuario
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId && !hasProtectedFields();
      allow delete: if false;
      
      // Subcolecciones de datos del usuario
      match /{collections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Catálogo global (Solo lectura / Solo admin u API escribe)
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if false; 
    }
  }
}
