# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# backups
backups/

.firebase/

# Logs de Firebase
firebase-debug.log
firebase-debug.*.log

# Archivos gigantes a ignorar
.firebase/
.tmp.driveupload/
node_modules/
**/node_modules/
.vercel
.env*.local
playwright-report/
test-results/

# Artefactos de build / logs que no deben commitearse
stash.diff
*.log
lint-error.log
vercel-deploy.log
vercel-error.log

# Scripts de migración/refactor de un solo uso
fix.js
refactorQuoteLogic.js
refactorSysConfig.js
export_migration_data.js

# Configuración local de Claude Code (launch.json sí se comparte)
.claude/settings.local.json
